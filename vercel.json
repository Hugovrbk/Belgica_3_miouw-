{
  "builds": [
    { "src": "**/*.php", "use": "vercel-php@0.7.2" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" },
    { "src": "multimedia/**", "use": "@vercel/static" },
    { "src": "**/*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.php" },
    { "src": "/(css|js|multimedia)/(.*)", "dest": "/$1/$2" },
    { "src": "/(.*\\.php)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
